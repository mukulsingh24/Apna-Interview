generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              Int      @id @default(autoincrement())
  firebaseUid     String   @unique
  fullName        String
  targetRole      String?
  experienceLevel String?
  education       String?
  skills          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ResumeAnalysis {
  id              Int      @id @default(autoincrement())
  firebaseUid     String
  fileName        String?
  atsScore        Int
  summary         String
  strengths       Json
  weaknesses      Json
  missingSections Json
  suggestions     Json
  createdAt       DateTime @default(now())
}