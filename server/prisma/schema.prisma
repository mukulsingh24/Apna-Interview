generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              Int      @id @default(autoincrement())
  firebaseUid     String   @unique
  fullName        String
  targetRole      String?
  experienceLevel String?
  education       String?
  skills          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ResumeAnalysis {
  id              Int      @id @default(autoincrement())
  firebaseUid     String
  fileName        String?
  atsScore        Int
  summary         String
  strengths       Json
  weaknesses      Json
  missingSections Json
  suggestions     Json
  createdAt       DateTime @default(now())
}

model JobMatchAnalysis {
  id               Int      @id @default(autoincrement())
  firebaseUid      String
  jobTitle         String?
  companyName      String?
  jobDescription   String   @db.Text
  atsScore         Int
  matchedSkills    Json
  missingSkills    Json
  matchedKeywords  Json
  missingKeywords  Json
  strengths        Json
  suggestions      Json
  createdAt        DateTime @default(now())
}

model InterviewSession {
  id              Int      @id @default(autoincrement())
  firebaseUid     String
  targetRole      String
  difficulty      String
  interviewType   String
  totalQuestions  Int
  overallScore    Int?
  questions       Json
  answers         Json?
  feedback        Json?
  status          String   @default("IN_PROGRESS")
  createdAt       DateTime @default(now())
  completedAt     DateTime?
}